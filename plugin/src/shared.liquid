{% template main %}
<style>.white__text { color: white; }</style>
<script>
  var __lcn = {{ items | json }};
  var __cfg = {
    view:        {{ view }},
    dateFmt:     {{ trmnl.plugin_settings.custom_fields_values.date_format | default: "%Y-%m-%d" | json }},
    name:        {{ trmnl.plugin_settings.instance_name | json }},
    poolWarning: {% if pool_warning %}{{ pool_warning }}{% else %}null{% endif %}
  };
</script>

<div class="layout lcn-layout h--full">
  <img class="lcn-img image image-dither image--contain rounded" alt="">
  <div class="lcn-panel flex--col stretch-x w--full 4bit:bg--gray-75 2bit:bg--gray-75 bg--gray-75 p--1 lg:p--2 m--1 outline rounded">
    <div class="lcn-name title rounded rounded--small w--full text--stroke">
      <div class="flex flex--row flex--center-y">
        <div class="flex flex--col gap--none" style="flex:1;min-width:0">
          <div class="lcn-name-main text--stroke mb--0__5 pb--0 w--full text--left font--bold" style="text-transform:uppercase" data-clamp="2"></div>
          <div class="lcn-name-sub pt--0 text--stroke w--full text--left" data-clamp="2"></div>
        </div>
        <div class="lcn-stats flex flex--row gap--xsmall no-shrink pl--1 {% if view == 1 or view == 4%} {% else %} hidden {% endif %}"></div>
      </div>
    </div>
    <div class="lcn-fields w--full mt--1" ></div>
    <div class="lcn-body hidden w--full description description--base lg:description--large m--0 p--0_5"></div>
    <div style="flex:1 1 0" class="h--min-1"></div>
    <div class="lcn-flavor-row hidden w--full text--left description {% if view != 4 %}description--large lg:description--xlarge{% else %}description--base lg:description--large {% endif %} bg--gray-20 white__text rounded rounded--small m--0 p--0_5">
      <div class="lcn-flavor w--full" style="font-style:italic"></div>
    </div>
  </div>
</div>

<div class="lcn-title-bar title_bar">
  <img class="image h--8" src="https://github.com/ExcuseMi/trmnl-lorcana-cards-plugin/blob/main/assets/logo.png?raw=true" alt="Lorcana">
  <span class="title lcn-title text--stroke"></span>
  <span class="lcn-pool-warning label label--warning" style="display:none"></span>
  <span class="instance p--2 lcn-instance"></span>
</div>

<script>
  function parseISODate(d) {
    var p = d.split('-').map(Number); return new Date(p[0], p[1]-1, p[2]);
  }
  function strftime(date, fmt) {
    var pad = function(n) { return String(n).padStart(2, '0'); };
    return fmt.replace(/%[Ymd]/g, function(m) {
      return m==='%Y' ? date.getFullYear() : m==='%m' ? pad(date.getMonth()+1) : pad(date.getDate());
    });
  }

  (function() {
    var views   = Array.from(document.querySelectorAll('.view'));
    var host    = document.currentScript.closest('.view') || document.body;
    var pool    = __lcn || [];
    var cfg     = __cfg;
    var viewIdx = views.indexOf(host) % 4;

    // Screen state from .screen element classes
    var screenEl = host.closest('.screen') || document.querySelector('.screen');
    var sc       = screenEl ? screenEl.classList : { contains: function(){ return false; } };
    var lg       = sc.contains('screen--lg');
    var md       = !lg;
    var portrait = sc.contains('screen--portrait');
    var bit1     = sc.contains('screen--1bit');
    var bit2     = sc.contains('screen--2bit');
    var bit4     = sc.contains('screen--4bit');

    var V = cfg.view;

    // Per-view CSS config — all layout/class strings live here, not in Liquid
    var VCFG = {
      1: {
        layout:   'layout--row gap--small',
        panel:    'flex portrait:hidden',
        gap:      'gap--small md:gap--small lg:gap--small',
        fieldsGap:'flex flex--col gap--small lg:gap--medium',
        gridGap:  'gap--small lg:gap--medium',
        name:     'label--large lg:label--xlarge p--3',

        lbl:      'label label--base lg:label--large pl--2 pr--3 pt--0_5 pb--0_5',
        val:      'description description--large lg:description--xlarge bg--white rounded rounded--small pt--0_5 pb--0_5 pl--2 pr--2',
        lblW:     'w--28 no-shrink',
        titleBar: 'lg:portrait:hidden',
        inst:     '',
        show_stats: true
      },
      2: {
        layout:   'layout--row gap--small',
        panel:    'flex portrait:hidden lg:portrait:flex',
        gap:      'md:gap--small lg:gap--small portrait:gap--none lg:portrait:gap--small',
        fieldsGap:'',
        name:     'label--base lg:label--large p--2',

        lbl:      'label label--small lg:label--base',
        val:      'description description--base lg:description--large bg--white rounded rounded--small pt--0_5 pb--0_5 pl--2 pr--2',
        lblW:     'w--24 no-shrink',
        titleBar: 'hidden portrait:flex',
        inst:     '',
        show_stats: true
      },
      3: {
        layout:   'layout--col gap--small',
        panel:    'hidden portrait:flex',
        gap:      'gap--small md:gap--small portrait:gap--small lg:portrait:gap--small',
        fieldsGap:'flex flex--col gap--medium',
        name:     'label--base lg:label--large p--2',

        lbl:      'label label--small lg:label--base',
        val:      'description description--base lg:description--large bg--white rounded rounded--small pt--0_5 pb--0_5 pl--2 pr--2',
        lblW:     'w--20 no-shrink',
        titleBar: 'hidden lg:flex lg:portrait:hidden',
        inst:     'md:portrait:hidden',
        show_stats: false
      },
      4: {
        layout:   'layout--row gap--small p--1',
        panel:    'flex portrait:hidden portrait:m::flex lg:portrait:hidden',
        gap:      'md:gap--small lg:gap--small portrait:gap--none lg:portrait:gap--small',
        fieldsGap:'flex flex--col gap--small',
        name:     'label--base lg:label--large p--2',

        lbl:      'label label--small lg:label--base',
        val:      'description description--base lg:description--large bg--white rounded rounded--small pt--0_5 pb--0_5 pl--2 pr--2',
        lblW:     'w--16 no-shrink',
        titleBar: 'hidden',
        inst:     'md:portrait:hidden',
        show_stats: false
      }
    };
    var vcfg = VCFG[V];

    function addCls(el, str) {
      if (!el || !str) return;
      str.trim().split(/\s+/).forEach(function(c) { if (c) el.classList.add(c); });
    }

    function q(sel) { return host.querySelector(sel); }
    var layoutEl   = q('.lcn-layout');
    var imgEl      = q('.lcn-img');
    var panelEl    = q('.lcn-panel');
    var nameEl     = q('.lcn-name');
    var nameMainEl = q('.lcn-name-main');
    var nameSubEl  = q('.lcn-name-sub');
    var statsEl    = q('.lcn-stats');
    var fieldsEl   = q('.lcn-fields');
    var bodyEl     = q('.lcn-body');
    var flavorRow  = q('.lcn-flavor-row');
    var flavorEl   = q('.lcn-flavor');
    var titleBarEl = q('.lcn-title-bar');
    var titleEl    = q('.lcn-title');
    var instEl     = q('.lcn-instance');
    var poolWarnEl = q('.lcn-pool-warning');

    addCls(layoutEl,   vcfg.layout);
    var usePortraitSizing = V === 1 ? (portrait && md)
                          : V === 2 ? false
                          : V === 3 ? true
                          : portrait;
    if (imgEl) addCls(imgEl, usePortraitSizing ? (V === 3 ? 'w--full' : 'w--full p--2') : 'h--full');
    addCls(panelEl,    vcfg.panel);
    if (V !== 3) addCls(panelEl, 'h--full');
    addCls(panelEl,    vcfg.gap);
    addCls(fieldsEl,   vcfg.fieldsGap);
    if (V === 2 && !(lg && portrait)) addCls(fieldsEl, 'grid grid--cols-2 gap--xsmall');
    addCls(nameEl,     vcfg.name);
    addCls(titleBarEl, vcfg.titleBar);
    addCls(instEl,     vcfg.inst);

    if (poolWarnEl && cfg.poolWarning) {
      poolWarnEl.textContent = cfg.poolWarning + ' cards';
      poolWarnEl.style.display = '';
    }

    var LABELS = {
      set:'Set', num:'No.', released:'Released', franchise:'Franchise',
      ink:'Ink', type:'Type', rarity:'Rarity', artist:'Artist'
    };

    var SYMBOLS = {
      w: '<svg viewBox="0 0 80 98" xmlns="http://www.w3.org/2000/svg" style="fill-rule:evenodd;clip-rule:evenodd;stroke-linecap:round;stroke-miterlimit:1.5"><g transform="matrix(0.905613,0,0,0.905613,0.257176,0.0133242)"><path d="M37.108,13.467L50.3,13.467L59.507,1.237L77.371,5.497L85.616,27.208L72.836,39.576C72.836,39.576 71.737,46.034 72.011,54.966L85.753,67.746L42.879,106.085L1.38,67.883L14.022,56.066C14.022,56.066 14.572,43.011 13.61,39.163L0.967,26.659L9.075,6.459L28.725,1.649L37.108,13.467Z" style="fill:black;stroke:white;stroke-width:2.5px"/><g transform="matrix(0.989156,0,0,0.977277,1.01518,1.14578)"><path d="M4.912,16.83C4.912,16.83 46.04,-3.848 80.943,18.414C80.943,18.414 66.103,30.231 74.073,66.234L43.154,92.756L13.61,66.372C13.61,66.372 20.263,31.736 4.912,16.83Z" style="fill:#222222;stroke:white;stroke-width:3.12px"/></g><g transform="matrix(1,0,0,0.98411,0,1.00877)"><path d="M6.189,31.606C6.189,31.606 9.35,44.935 5.64,63.486" style="fill:black;stroke:white;stroke-width:2.07px"/></g><g transform="matrix(0.864571,0,0,0.979856,10.9044,1.29272)"><path d="M81.905,30.644C81.905,30.644 78.607,45.759 82.18,64.173" style="fill:black;stroke:white;stroke-width:2.22px"/></g><g transform="matrix(1,0,0,1,0.393999,-0.50657)"><path d="M74.073,65.96C74.073,65.96 75.447,69.945 78.333,74.205" style="fill:black;stroke:white;stroke-width:2.05px"/></g><g transform="matrix(1,0,0,1,0.562855,-0.112571)"><path d="M13.472,66.372C13.472,66.372 10.999,71.044 7.976,74.205" style="fill:black;stroke:white;stroke-width:2.05px"/></g></g></svg>',
