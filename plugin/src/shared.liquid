3,52.484 84.217,50.027 81.58,48.504C79.926,46.614 78.925,43.09 78.925,43.09C77.478,44.23 76.925,48.511 76.925,48.511Z" fill="currentcolor"/></g></svg>'
    };

    var KW_RE = /\b(Rush|Evasive|Ward|Bodyguard|Singer|Shift|Support|Reckless|Resist|Challenger|Vanish|Voracious)(\s[+\-]?\d+)?(?=[\s(]|$)/g;

    function replaceSymbols(text) {
      return text
        .replace(/\n/g, '<br>')
        .replace(/\{([wsli])\}/g, function(_, k) {
          var svg = SYMBOLS[k];
          return svg
            ? '<span style="display:inline-block;width:1em;height:1em;vertical-align:text-bottom">' + svg + '</span>'
            : '{' + k + '}';
        })
        .replace(/\b([A-Z]{2,}(?:\s+[A-Z]+)*)(?=\s*:)/g, '<span class="label label--inverted">$1</span>')
        .replace(KW_RE, '<span class="label label--inverted">$1$2</span>');
    }

    // Field config per view. Views 2 & 4 are bp-objects {md:[...], lg:[...]}.
    var FIELDS = {
      1: ['set','num','released','franchise','ink','type','rarity','artist'],
      2: {
        md: ['set','num','released','franchise','ink','type','rarity','artist'],
        lg: ['set','num','released','franchise','ink','type','rarity','artist']
      },
      3: ['set','num','released','franchise','ink','type','rarity','artist'],
      4: {
        md: ['set','num','ink','type','rarity'],
        lg: ['set','num','released','franchise','ink','type','rarity','artist']
      }
    };

    function getFields() {
      var def = FIELDS[V];
      if (Array.isArray(def)) return def;
      var bp = (lg && !(V === 2 && portrait)) ? 'lg' : 'md';
      return def[bp] || def.md;
    }

    function makeStat(sym, val) {
      var wrap = document.createElement('div');
      var isCost = sym === 'i' || sym === 'inkpot';
      var dark   = sym === 'w';
      var bgColor   = isCost ? '#000' : dark ? '#1a1a1a' : 'white';
      var iconColor = isCost ? '#d5b987' : dark ? (bit1 ? 'black' : 'darkgray') : '#1a1a1a';
      var textColor = isCost || dark ? 'white' : '#1a1a1a';
      wrap.style.cssText = 'position:relative;width:2.3em;height:2.3em;display:flex;align-items:center;justify-content:center;flex-shrink:0';
      var icon = document.createElement('span');
      icon.className = ' image-dither';
      icon.style.cssText = 'position:absolute;inset:0;color:' + iconColor;
      icon.innerHTML = SYMBOLS[sym];
      var num = document.createElement('span');
      num.style.cssText = 'position:relative;z-index:1;font-weight:bold;font-size:0.9em;line-height:1;color:' + textColor;
      num.textContent = String(val);
      if (isCost) {
        var bg = document.createElement('div');
        bg.style.cssText = 'position:absolute;inset:0.25em;border-radius:50%;background:' + bgColor;
        wrap.appendChild(bg);
      }
      wrap.appendChild(icon);
      wrap.appendChild(num);
      return wrap;
    }

    function getValue(item, k) {
      switch (k) {
        case 'set':      return item.set_name || null;
        case 'num':      return item.card_num != null
                           ? (item.set_total_cards
                               ? item.card_num + ' of ' + item.set_total_cards
                               : String(item.card_num))
                           : null;
        case 'released': return item.set_release_date
                           ? strftime(parseISODate(item.set_release_date), cfg.dateFmt)
                           : null;
        case 'franchise':return item.franchise || null;
        case 'ink':      return item.color || null;
        case 'type': {
          var cls = item.classifications && item.classifications.filter(Boolean);
          if ((item.type || '').toLowerCase() === 'character' && cls && cls.length)
            return cls.join(' · ');
          return cls ? [item.type].concat(cls).join(' · ') : item.type || null;
        }
        case 'rarity':   return item.rarity || null;
        case 'artist':   return item.artist || null;
        case 'cost':     return item.cost ? item.cost + ' ◆' : null;
        case 'lore':     return item.lore ? item.lore + ' ◆' : null;
        case 'str':      return item.strength || null;
        case 'will':     return item.willpower || null;
        default:         return null;
      }
    }

    function makeRow(k, v) {
      var outer = document.createElement('div');
      outer.className = 'item p--0 m--0';
      var inner = document.createElement('div');
      inner.className = 'content flex flex--row flex--center-y gap--small';
      var lbl = document.createElement('span');
      lbl.className = vcfg.lbl + ' ' + vcfg.lblW;
      lbl.textContent = LABELS[k] || k;
      var val = document.createElement('span');
      val.className = vcfg.val;
      val.textContent = String(v);
      inner.appendChild(lbl);
      inner.appendChild(val);
      outer.appendChild(inner);
      return outer;
    }

    function renderFields(el, item, maxFields) {
      el.innerHTML = '';
      var count = 0;
      getFields().forEach(function(def) {
        if (count >= maxFields) return;
        var keys  = Array.isArray(def) ? def : [def];
        var pairs = keys.map(function(k) { return { k: k, v: getValue(item, k) }; })
                        .filter(function(p) { return p.v != null; });
        if (!pairs.length) return;
        if (keys.length > 1) {
          var g = document.createElement('div');
          g.className = 'grid grid--cols-2 ' + (vcfg.gridGap || 'gap--xsmall') + ' w--full';
          pairs.forEach(function(p) { g.appendChild(makeRow(p.k, p.v)); });
          el.appendChild(g);
        } else {
          el.appendChild(makeRow(pairs[0].k, pairs[0].v));
        }
        count++;
      });
    }

    var nameBase = nameEl ? nameEl.className : '';

    if (!pool.length) {
      if (titleEl) titleEl.textContent = cfg.name;
      return;
    }

    var tried = new Set();

    function tryNext() {
      for (var i = 0; i < pool.length; i++) {
        var idx = (viewIdx + i) % pool.length;
        if (!tried.has(idx)) { tried.add(idx); render(pool[idx]); return; }
      }
      if (titleEl) titleEl.textContent = cfg.name;
    }

    function rarityClass(r) {
      r = (r || '').toLowerCase();
      if (r === 'enchanted')
        return 'bg--red 1bit:text--white 1bit:bg--black 2bit:text--white 2bit:bg--black 4bit:text--white 4bit:bg--black';
      if (r === 'legendary')
        return 'bg--yellow 1bit:text--white 1bit:bg--gray-30 2bit:text--white 2bit:bg--gray-30 4bit:text--white 4bit:bg--gray-30';
      if (r === 'super rare' || r === 'rare')
        return 'bg--yellow-50 1bit:text--white 1bit:bg--gray-40 2bit:text--white 2bit:bg--gray-40 4bit:text--white 4bit:bg--gray-40';
      return 'bg--gray-65 text--stroke';
    }

    function render(item) {
      if (!item || !item.image) { if (titleEl) titleEl.textContent = cfg.name; return; }

      if (flavorRow) flavorRow.classList.add('hidden');
      if (bodyEl)   bodyEl.classList.add('hidden');
      if (nameEl) {
        nameEl.className = nameBase;
        rarityClass(item.rarity).trim().split(/\s+/).forEach(function(c) { if (c) nameEl.classList.add(c); });
        var dashIdx = (item.name || '').indexOf(' - ');
        var mainName = dashIdx >= 0 ? item.name.slice(0, dashIdx) : (item.name || '');
        var subName  = dashIdx >= 0 ? item.name.slice(dashIdx + 3) : '';
        if (nameMainEl) {
          nameMainEl.className = 'lcn-name-main text--stroke mb--0__5 pb--0 w--full text--left font--bold';
          if (V === 4) { nameMainEl.classList.add(lg ? 'description--large' : 'description'); }
          else { nameMainEl.classList.add('title', subName ? 'title--xlarge' : 'title--large'); }
          nameMainEl.textContent = mainName;
        }
        if (nameSubEl) {
          nameSubEl.className = 'lcn-name-sub pt--0 text--stroke w--full text--left';
          nameSubEl.classList.add(V === 4 ? (lg ? 'description--large' : 'description') : 'description--xlarge');
          nameSubEl.textContent = subName;
          nameSubEl.style.display = subName ? '' : 'none';
        }
      }
      if (statsEl && vcfg.show_stats) {
        statsEl.innerHTML = '';
        if (item.strength != null) statsEl.appendChild(makeStat('s', item.strength));
        if (item.willpower != null) statsEl.appendChild(makeStat('w', item.willpower));
      }

      var imgs    = Array.from(host.querySelectorAll('.lcn-img'));
      var errored = false;
      function onImgError() {
        if (errored) return; errored = true;
        imgs.forEach(function(img) { img.onerror = null; });
        tryNext();
      }
      imgs.forEach(function(img) { img.onerror = onImgError; img.src = item.image; img.alt = item.name || ''; });

      var showFlavor = item.flavor_text &&
                       (V !== 4 || item.flavor_text.length <= 75);
      var maxFields  = V === 4 ? (showFlavor ? (lg ? 5 : 4) : 7)
                     : V === 2 ? (showFlavor ? (lg ? 12 : 10) : 12)
                     : Infinity;
      if (fieldsEl) renderFields(fieldsEl, item, maxFields);

      var showBody = item.body_text && V !== 4 && !showFlavor && !(V === 2 && md);
      if (showBody && bodyEl) {
        bodyEl.innerHTML = replaceSymbols(item.body_text);
        bodyEl.setAttribute('data-clamp', V === 1 ? '6' : V === 2 ? '4' : '3');
        bodyEl.classList.remove('hidden');
      }

      if (showFlavor) {
        if (flavorEl)  flavorEl.textContent = item.flavor_text;
        if (flavorRow) flavorRow.classList.remove('hidden');
      }

      if (titleEl) titleEl.textContent = item.name || '';
      if (instEl)  instEl.textContent  = item.set_name || '';
    }

    tryNext();
  })();
</script>

{% endtemplate %}
